{
  "name": "rhw-knowledge-search",
  "version": "0.1.0",
  "description": "AI-powered knowledge search crawler for RHW CPAs",
  "type": "module",
  "main": "crawler/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "crawl": "node crawler/index.js",
    "crawl:test": "node crawler/index.js --path ./test-docs",
    "crawl:full": "node crawler/index.js --path P:\\\\Data --full",
    "setup-db": "node scripts/setup-db.js",
    "search": "node scripts/search.js"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.8.0",
    "xlsx": "^0.18.5",
    "openai": "^4.50.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {}
}
